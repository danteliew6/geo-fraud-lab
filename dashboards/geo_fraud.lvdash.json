{
  "datasets": [
    {
      "name": "kpis",
      "displayName": "kpis",
      "queryLines": [
        "SELECT MEASURE(total_disbursed) AS total_disbursed,\n",
        "       MEASURE(active_borrowers) AS active_borrowers,\n",
        "       MEASURE(npl_ratio) AS npl_ratio,\n",
        "       MEASURE(par30) AS par30,\n",
        "       CAST(MEASURE(approval_rate) AS DOUBLE) AS approval_rate,\n",
        "       CAST(MEASURE(fraud_rate) AS DOUBLE) AS fraud_rate,\n",
        "       MEASURE(fraud_amount) AS fraud_amount,\n",
        "       MEASURE(num_flagged_applications) AS flagged_applications\n",
        "FROM metrics_lending"
      ]
    },
    {
      "name": "hotspots",
      "displayName": "hotspots",
      "queryLines": [
        "SELECT latitude, longitude, province, applications, fraud_applications,\n",
        "       CAST(fraud_rate AS DOUBLE) AS fraud_rate\n",
        "FROM vw_ls_fraud_hotspots\n",
        "WHERE applications >= 3"
      ]
    },
    {
      "name": "fraud_province",
      "displayName": "fraud_province",
      "queryLines": [
        "SELECT province,\n",
        "       CAST(fraud_rate AS DOUBLE) AS fraud_rate,\n",
        "       applications, fraud_applications, fraud_amount_idr\n",
        "FROM vw_ls_fraud_by_province\n",
        "ORDER BY fraud_rate DESC"
      ]
    },
    {
      "name": "impossible_travel",
      "displayName": "impossible_travel",
      "queryLines": [
        "SELECT application_id, customer_id,\n",
        "       ROUND(distance_km,0) AS distance_km,\n",
        "       ROUND(implied_speed_kmh,0) AS implied_speed_kmh,\n",
        "       home_province, application_province, requested_amount_idr, ip_country\n",
        "FROM vw_ls_impossible_travel\n",
        "ORDER BY implied_speed_kmh DESC"
      ]
    },
    {
      "name": "fraud_rings",
      "displayName": "fraud_rings",
      "queryLines": [
        "SELECT device_id, num_applications, num_customers, fraud_applications,\n",
        "       CAST(fraud_rate AS DOUBLE) AS fraud_rate,\n",
        "       ROUND(total_requested_idr/1e9,2) AS total_requested_bn\n",
        "FROM vw_ls_fraud_rings\n",
        "ORDER BY num_customers DESC"
      ]
    },
    {
      "name": "fraud_trend",
      "displayName": "fraud_trend",
      "queryLines": [
        "SELECT application_month, applications, fraud_applications,\n",
        "       CAST(fraud_rate AS DOUBLE) AS fraud_rate,\n",
        "       ROUND(fraud_amount_idr/1e9,2) AS fraud_amount_bn\n",
        "FROM vw_ls_fraud_by_month\n",
        "ORDER BY application_month"
      ]
    },
    {
      "name": "correlation",
      "displayName": "correlation",
      "queryLines": [
        "SELECT Province AS province,\n",
        "       CAST(MEASURE(fraud_rate) AS DOUBLE) AS fraud_rate,\n",
        "       CAST(MEASURE(par30) AS DOUBLE) AS par30,\n",
        "       CAST(MEASURE(npl_ratio) AS DOUBLE) AS npl_ratio,\n",
        "       MEASURE(total_disbursed) AS total_disbursed\n",
        "FROM metrics_lending\n",
        "GROUP BY Province\n",
        "ORDER BY fraud_rate DESC"
      ]
    },
    {
      "name": "distance_bands",
      "displayName": "distance_bands",
      "queryLines": [
        "SELECT band, applications, fraud_applications,\n",
        "       ROUND(fraud_applications/applications,4) AS fraud_rate\n",
        "FROM (\n",
        "  SELECT CASE\n",
        "           WHEN home_distance_km < 10 THEN '1 | 0-10 km'\n",
        "           WHEN home_distance_km < 50 THEN '2 | 10-50 km'\n",
        "           WHEN home_distance_km < 200 THEN '3 | 50-200 km'\n",
        "           WHEN home_distance_km < 500 THEN '4 | 200-500 km'\n",
        "           WHEN home_distance_km < 1000 THEN '5 | 500-1000 km'\n",
        "           ELSE '6 | 1000+ km' END AS band,\n",
        "         COUNT(*) AS applications,\n",
        "         SUM(CASE WHEN is_fraud THEN 1 ELSE 0 END) AS fraud_applications\n",
        "  FROM vw_fraud_signals\n",
        "  WHERE home_distance_km IS NOT NULL\n",
        "  GROUP BY 1)\n",
        "ORDER BY band"
      ]
    }
  ],
